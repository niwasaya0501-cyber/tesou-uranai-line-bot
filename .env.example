# LINE Developers > Messaging APIチャンネル > チャンネル基本設定 で確認できる値
LINE_CHANNEL_SECRET=your_channel_secret_here

# LINE Developers > Messaging APIチャンネル > Messaging API設定 で発行する長期トークン
LINE_CHANNEL_ACCESS_TOKEN=your_long_lived_channel_access_token_here

# OpenAI Platform (https://platform.openai.com/api-keys) で発行するAPIキー
OPENAI_API_KEY=sk-your_openai_api_key_here

# LINE Developers > LINEログインチャンネル > LIFF で追加したLIFFアプリのID（数字-英数字の形式）
LIFF_ID=1234567890-abcdefgh

# Vercel Storage > Upstash for Redis（無料枠）を作成しプロジェクトに接続すると自動追加される値
# LINEトーク上での「ラリー（続きの会話）」の履歴を一時保存するために使用
KV_REST_API_URL=https://xxxxx.upstash.io
KV_REST_API_TOKEN=your_upstash_rest_token_here
